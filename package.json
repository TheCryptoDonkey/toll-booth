{
  "name": "toll-booth",
  "version": "1.0.0",
  "type": "module",
  "description": "L402 Lightning payment middleware for any Node.js framework — Express, Hono, Deno, Bun",
  "license": "MIT",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./backends/phoenixd": { "import": "./dist/backends/phoenixd.js", "types": "./dist/backends/phoenixd.d.ts" },
    "./backends/lnd": { "import": "./dist/backends/lnd.js", "types": "./dist/backends/lnd.d.ts" },
    "./backends/alby": { "import": "./dist/backends/alby.js", "types": "./dist/backends/alby.d.ts" },
    "./storage/sqlite": { "import": "./dist/storage/sqlite.js", "types": "./dist/storage/sqlite.d.ts" },
    "./storage/memory": { "import": "./dist/storage/memory.js", "types": "./dist/storage/memory.d.ts" },
    "./adapters/hono": { "import": "./dist/adapters/hono.js", "types": "./dist/adapters/hono.d.ts" },
    "./adapters/express": { "import": "./dist/adapters/express.js", "types": "./dist/adapters/express.d.ts" },
    "./adapters/web-standard": { "import": "./dist/adapters/web-standard.js", "types": "./dist/adapters/web-standard.d.ts" }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "macaroon": "^3.0.4",
    "qrcode": "^1.5.4"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "hono": { "optional": true },
    "express": { "optional": true }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.9",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "hono": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "ws": "^8.19.0"
  }
